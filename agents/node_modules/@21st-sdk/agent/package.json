{
  "name": "@21st-sdk/agent",
  "version": "0.0.16",
  "license": "MIT",
  "description": "Define AI agents and tools with full type inference for 21st Agents",
  "homepage": "https://21st.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "ai",
    "agent",
    "tools",
    "21st",
    "21st.dev",
    "sdk",
    "claude",
    "codex"
  ],
  "peerDependencies": {
    "zod": ">=3.24"
  },
  "dependencies": {
    "@21st-sdk/node": "^0.0.9"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "zod": "^3.24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  }
}