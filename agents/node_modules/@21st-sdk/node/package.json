{
  "name": "@21st-sdk/node",
  "version": "0.0.9",
  "license": "MIT",
  "description": "Server-side Node.js SDK for 21st Agents",
  "homepage": "https://21st.dev/agents",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "docs/**/*",
    "src",
    "!src/**/*.test.ts",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "directories": {
    "doc": "./docs"
  },
  "keywords": [
    "ai",
    "agent",
    "sandbox",
    "21st",
    "21st.dev",
    "sdk",
    "node"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  }
}